<!--
  Label Studio labeling config for Padel Court Keypoint Annotation.

  This template defines 12 court keypoints matching PadelCourtModel.KEYPOINTS
  in src/padex/tracking/court.py.

  Court coordinate system:
    Origin = bottom-left corner
    x: 0-10m (width), y: 0-20m (length)
    Net at y = 10.0

  Keypoint layout (top-down view):

    top_left (0,20) ──── service_far_left (0,17) ──── net_left (0,10) ──── service_near_left (0,3) ──── bottom_left (0,0)
         |                     |                           |                      |                           |
    top_right(10,20)── service_far_right(10,17)── net_right(10,10) ── service_near_right(10,3) ── bottom_right(10,0)
                         service_far_center(5,17)                    service_near_center(5,3)

  Instructions for annotators:
    1. Place each keypoint at the INTERSECTION of the relevant court lines.
    2. If a keypoint is occluded (by net, player, glass, etc.), estimate its
       position as accurately as possible — still place the point.
    3. If a keypoint is completely invisible and cannot be estimated, skip it
       (don't place that specific keypoint).
    4. "bottom" = closer to camera (near side), "top" = farther from camera (far side)
       in standard broadcast perspective.
-->
<View>
  <Header value="Padel Court Keypoint Annotation"/>
  <Text name="instructions" value="Mark each visible court keypoint. If a point is occluded but its position can be estimated, place it and add a per-region tag 'occluded'. Skip points that are completely invisible."/>

  <Image name="image" value="$image" zoom="true" zoomControl="true" rotateControl="false"/>

  <KeyPointLabels name="keypoints" toName="image" strokeWidth="3" fillColor="rgba(255,0,0,0.5)">
    <!-- Outer corners -->
    <Label value="bottom_left" background="#FF0000"/>
    <Label value="bottom_right" background="#FF4444"/>
    <Label value="top_left" background="#0000FF"/>
    <Label value="top_right" background="#4444FF"/>

    <!-- Net-sideline intersections -->
    <Label value="net_left" background="#FFFF00"/>
    <Label value="net_right" background="#FFFF44"/>

    <!-- Service line near side (y=3, 7m from net) -->
    <Label value="service_near_left" background="#00FF00"/>
    <Label value="service_near_center" background="#00CC00"/>
    <Label value="service_near_right" background="#009900"/>

    <!-- Service line far side (y=17, 7m from net) -->
    <Label value="service_far_left" background="#FF00FF"/>
    <Label value="service_far_center" background="#CC00CC"/>
    <Label value="service_far_right" background="#990099"/>
  </KeyPointLabels>

  <!-- Per-keypoint visibility tag -->
  <Choices name="visibility" toName="image" perRegion="true" required="false">
    <Choice value="visible" selected="true"/>
    <Choice value="occluded"/>
  </Choices>
</View>
